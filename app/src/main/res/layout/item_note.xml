<?xml version="1.0" encoding="utf-8"?>
<com.apachat.swipereveallayout.core.SwipeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="horizontal"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:mode="same_level"
    app:dragEdge="right"
    android:id="@+id/layout_item_note">

    <!--  Layout swipe (hay dùng LinearLayout để chia đều các đối tượng) -->
    <LinearLayout
        android:id="@+id/layout_all_swipe_item_notes"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:paddingStart="10dp"
        tools:ignore="RtlSymmetry,VisualLintBounds">

        <RelativeLayout
            android:id="@+id/layout_swipe_delete_note_avatar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:background="@drawable/bg_swipe_edit_event"
            android:padding="10dp"
            android:layout_marginTop="3dp"
            android:layout_marginBottom="3dp"
            android:layout_marginEnd="3dp">
            <ImageView
                android:id="@+id/img_swipe_delete_note_avatar"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@drawable/ic_delete_2_image"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/contentDescription" />
        </RelativeLayout>

        <RelativeLayout
            android:id="@+id/layout_swipe_delete_note_item"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:background="@drawable/bg_swipe_delete_event"
            android:padding="10dp"
            android:layout_marginTop="3dp"
            android:layout_marginBottom="3dp"
            android:layout_marginEnd="3dp">
            <ImageView
                android:id="@+id/img_swipe_delete_note_item"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@drawable/ic_delete_1"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/contentDescription" />
        </RelativeLayout>

    </LinearLayout>

    <!--  Layout item  -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        tools:ignore="TextSizeCheck">

        <LinearLayout
            android:id="@+id/layout_all_note_item"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:minHeight="48dp"
            android:orientation="horizontal"
            tools:ignore="DisableBaselineAlignment,TextSizeCheck">

            <LinearLayout
                android:id="@+id/layout_textView_note"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:layout_marginEnd="2dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:visibility="visible"
                tools:ignore="UselessParent">

                <TextView
                    android:id="@+id/textView_note_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:layout_marginEnd="3dp"
                    android:layout_weight="1"
                    android:paddingStart="@dimen/primary_padding_activity"
                    android:text="@string/text_event"
                    android:textColor="@color/primary_text"
                    android:textSize="@dimen/text_event"
                    tools:ignore="NestedWeights,RtlSymmetry" />

                <ImageView
                    android:id="@+id/img_note_avatar"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:layout_marginTop="3dp"
                    android:layout_marginBottom="3dp"
                    android:layout_gravity="center_vertical"
                    android:layout_marginEnd="@dimen/primary_padding_activity"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/contentDescription"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_picture_1"
                    android:visibility="visible"
                    tools:ignore="ImageContrastCheck" />

            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/layout_note_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:gravity="end"
            android:orientation="vertical"
            android:paddingBottom="3dp">

            <TextView
                android:id="@+id/txt_note_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_marginTop="1dp"
                android:layout_marginEnd="@dimen/primary_padding_activity"
                android:paddingStart="@dimen/primary_padding_activity"
                android:text="@string/time"
                android:textColor="@color/primary_text"
                android:textSize="@dimen/text_date_on_rcv"
                tools:ignore="RtlSymmetry" />

        </LinearLayout>
    </LinearLayout>

</com.apachat.swipereveallayout.core.SwipeLayout>