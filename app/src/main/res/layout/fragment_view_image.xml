<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary_activity"
    android:id="@+id/layout_view_full_image_event"
    tools:context=".calendarview.event.viewimage.ViewImageFragment">

    <com.ortiz.touchview.TouchImageView
        android:id="@+id/imageView_image_fragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="3dp"
        android:layout_marginBottom="3dp"
        android:layout_alignParentTop="true"
        android:layout_above="@+id/line_view_image"
        android:scaleType="centerInside"
        android:src="@drawable/banner_falun_1"
        tools:ignore="SpeakableTextPresentCheck" />

<!--  ở đây back trên từng item luôn vì tiện có menu control  -->
    <TextView
        android:id="@+id/line_view_image"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/gray_2"
        android:layout_above="@+id/layout_menu_view_event_image"/>

    <RelativeLayout
        android:id="@+id/layout_menu_view_event_image"
        android:layout_alignParentBottom="true"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:background="@color/white"
        android:animateLayoutChanges="true"
        android:gravity="center_vertical"
        android:visibility="visible"
        android:elevation="5dp">

        <ImageView
            android:id="@+id/icon_back_view_full_image"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="6dp"
            android:layout_marginStart="10dp"
            android:layout_alignParentStart="true"
            android:src="@drawable/ic_arrow_back_96"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            tools:ignore="SpeakableTextPresentCheck,TouchTargetSizeCheck" />

        <ImageView
            android:id="@+id/icon_save_view_full_image"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="8dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_download_image_1"
            android:layout_centerHorizontal="true"/>

        <ImageView
            android:id="@+id/icon_delete_view_full_image"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="8dp"
            android:layout_marginEnd="8dp"
            android:src="@drawable/ic_delete_event_image_1"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:layout_alignParentEnd="true"/>

    </RelativeLayout>

</RelativeLayout>