<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary_activity"
    android:orientation="vertical"
    tools:context=".notes.UpdateNoteViewAllFragment">

    <RelativeLayout
        android:id="@+id/layout_title_new_note"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@color/white"
        android:focusable="true"
        android:clickable="true"
        android:focusableInTouchMode="true"
        android:elevation="3dp">

        <ImageButton
            android:id="@+id/ic_back_new_note"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:padding="5dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:paddingStart="@dimen/primary_padding_activity"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_arrow_back_96"
            tools:ignore="ContentDescription,RtlSymmetry,SpeakableTextPresentCheck,TouchTargetSizeCheck"
            android:visibility="visible"/>

        <TextView
            android:id="@+id/txt_title_note_activity"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="@string/title_new_note"
            android:textColor="@color/black"
            android:textSize="@dimen/text_title_update_event"
            android:textStyle="bold"
            tools:ignore="RelativeOverlap" />

        <ImageView
            android:id="@+id/img_view_avatar_new_note"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:layout_marginEnd="@dimen/primary_padding_activity"
            android:foreground="?android:attr/selectableItemBackgroundBorderless"
            android:importantForAccessibility="no"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_add_photo_4"
            tools:ignore="ImageContrastCheck" />

    </RelativeLayout>

    <ScrollView
        android:id="@+id/scrollView_add_event"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@+id/layout_title_new_note"
        tools:ignore="UselessParent">

        <!--  Out các focus của edt khi click ra ngoài edt (click vào layout cha)  -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            tools:ignore="ScrollViewSize"
            android:focusable="true"
            android:clickable="true"
            android:focusableInTouchMode="true">

            <!-- Bắt đầu nội dung -->
            <RelativeLayout
                android:id="@+id/layout_edt_new_note_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingLeft="@dimen/primary_padding_activity"
                android:paddingRight="@dimen/primary_padding_activity">

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/textInPutLayout_new_note_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:endIconMode="clear_text"
                    android:layout_marginTop="5dp">

                    <EditText
                        android:id="@+id/edt_new_note_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:autofillHints="@string/new_note"
                        android:background="@drawable/bg_edt_event_name"
                        android:inputType="textMultiLine|textCapSentences"
                        android:minHeight="48dp"
                        android:padding="10dp"
                        android:textSize="@dimen/edt_add_event"
                        android:scrollHorizontally="true"
                        android:layout_alignParentStart="true"
                        tools:ignore="LabelFor,SpeakableTextPresentCheck,VisualLintTextFieldSize"/>

                </com.google.android.material.textfield.TextInputLayout>

                <RelativeLayout
                    android:id="@+id/layout_content_of_new_note"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@+id/textInPutLayout_new_note_name"
                    android:layout_gravity="center">

                    <EditText
                        android:id="@+id/edt_content_new_note"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_note_event"
                        android:gravity="top"
                        android:inputType="textMultiLine|textCapSentences"
                        android:minHeight="@dimen/height_edt_content_note"
                        android:padding="10dp"
                        android:layout_marginTop="@dimen/space_add_event"
                        android:scrollHorizontally="false"
                        android:textSize="@dimen/edt_add_event"
                        tools:ignore="Autofill,LabelFor,SpeakableTextPresentCheck,VisualLintTextFieldSize"
                        android:visibility="visible"/>

                    <ImageButton
                        android:id="@+id/ibtn_clear_content_new_note"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:padding="5dp"
                        android:layout_marginTop="6dp"
                        android:layout_below="@+id/edt_content_new_note"
                        android:layout_alignParentStart="true"
                        android:layout_alignParentBottom="true"
                        android:scaleType="centerInside"
                        android:src="@drawable/ic_cancel_2"
                        android:background="?android:attr/selectableItemBackgroundBorderless"
                        tools:ignore="SpeakableTextPresentCheck"
                        android:contentDescription="@string/contentDescription"
                        android:visibility="gone"/>

                    <ImageButton
                        android:id="@+id/ibtn_copy_note_content"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:layout_below="@+id/edt_content_new_note"
                        android:layout_centerHorizontal="true"
                        android:layout_marginTop="6dp"
                        android:background="?android:attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/contentDescription"
                        android:padding="4dp"
                        android:scaleType="centerInside"
                        android:src="@drawable/ic_copy_1"
                        android:visibility="gone"
                        tools:ignore="SpeakableTextPresentCheck" />

                    <ImageButton
                        android:id="@+id/ibtn_check_content_new_note"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:padding="5dp"
                        android:layout_marginTop="6dp"
                        android:layout_below="@+id/edt_content_new_note"
                        android:layout_alignParentEnd="true"
                        android:layout_alignParentBottom="true"
                        android:scaleType="centerInside"
                        android:src="@drawable/ic_check_edit_text_3"
                        android:background="?android:attr/selectableItemBackgroundBorderless"
                        tools:ignore="SpeakableTextPresentCheck"
                        android:contentDescription="@string/contentDescription"
                        android:visibility="gone"/>

                </RelativeLayout>

                <RelativeLayout
                    android:id="@+id/layout_control_rcv_new_note"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@+id/layout_content_of_new_note"
                    android:focusable="true"
                    android:clickable="true"
                    android:focusableInTouchMode="true"
                    android:visibility="visible">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rcv_image_new_note"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_add_event"
                        android:paddingEnd="12dp"
                        android:background="@drawable/bg_note_event"
                        tools:ignore="RtlSymmetry" />

                    <ProgressBar
                        android:id="@+id/pb_list_image_note_update"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:layout_marginTop="10dp"
                        android:layout_centerInParent="true"
                        android:visibility="gone" />

                </RelativeLayout>

                <RelativeLayout
                    android:id="@+id/layout_icon_control_image_new_note"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@+id/layout_control_rcv_new_note"
                    android:layout_marginTop="5dp"
                    android:orientation="horizontal"
                    android:visibility="gone">

                    <ImageView
                        android:id="@+id/img_delete_all_image_new_note"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_delete_event_image_2"
                        android:padding="5dp"
                        android:layout_alignParentStart="true"
                        android:background="?android:attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/contentDescription" />

                    <ImageView
                        android:id="@+id/img_check_add_image_new_note"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_check_edit_text_3"
                        android:padding="10dp"
                        android:layout_alignParentEnd="true"
                        android:background="?android:attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/contentDescription"/>

                </RelativeLayout>

                <Button
                    android:id="@+id/btn_save_new_note"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@+id/layout_icon_control_image_new_note"
                    android:layout_marginTop="@dimen/space_btn_add_event"
                    android:layout_centerHorizontal="true"
                    android:background="@drawable/ripple_effect_click"
                    android:text="@string/save"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="@dimen/text_save_cancel"
                    android:textStyle="bold"
                    tools:ignore="TextContrastCheck,VisualLintButtonSize" />

                <Button
                    android:id="@+id/btn_cancel_new_note"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@+id/btn_save_new_note"
                    android:layout_centerHorizontal="true"
                    android:layout_gravity="center"
                    android:layout_marginTop="@dimen/space_btn_add_event"
                    android:layout_marginBottom="@dimen/space_end_btn_add_event"
                    android:background="@drawable/ripple_effect_click_button_cancel"
                    android:paddingLeft="10dp"
                    android:paddingRight="10dp"
                    android:text="@string/back"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="@dimen/text_save_cancel"
                    android:textStyle="bold"
                    tools:ignore="TextContrastCheck" />

            </RelativeLayout>

        </RelativeLayout>

    </ScrollView>

</RelativeLayout>