<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".menu.MenuHowHumankindCameToBeFragment">

    <RelativeLayout
        android:id="@+id/layout_fragment_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="5dp"
        android:minHeight="48dp"
        android:background="@color/white"
        android:elevation="5dp">

        <ImageButton
            android:id="@+id/ic_back_menu_privacy_policy_fm"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:padding="5dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:paddingStart="@dimen/primary_padding_activity"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_arrow_back_96"
            tools:ignore="ContentDescription,RtlSymmetry,SpeakableTextPresentCheck,TouchTargetSizeCheck"
            android:visibility="visible"/>

        <TextView
            android:id="@+id/txt_title_menu_privacy_policy"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="@string/how_human_kind_came_to_be"
            android:textAlignment="center"
            android:textColor="@color/black"
            android:textSize="@dimen/title_list_all_event"
            android:textStyle="bold"
            android:visibility="visible"
            tools:ignore="RtlSymmetry" />

        <ImageButton
            android:id="@+id/ibtn_copy_content_post"
            android:layout_width="33dp"
            android:layout_height="33dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:layout_marginTop="6dp"
            android:layout_marginEnd="@dimen/primary_padding_activity"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/contentDescription"
            android:padding="6dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_copy_1"
            android:visibility="gone"
            tools:ignore="SpeakableTextPresentCheck,TouchTargetSizeCheck" />

    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@+id/layout_fragment_title">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="@dimen/primary_padding_activity">

            <TextView
                android:id="@+id/how_humankind_came_to_be_content"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="@string/why_there_is_mankind_link"
                android:textAlignment="viewStart"
                android:textSize="@dimen/text_post"
                android:textColor="@color/black"
                tools:ignore="VisualLintLongText" />

        </RelativeLayout>

    </ScrollView>

</RelativeLayout>